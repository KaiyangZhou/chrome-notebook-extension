{
  "manifest_version": 3,
  "name": "Simple Notes",
  "version": "1.0.0",
  "description": "Write notes in a side panel.",
  "permissions": ["storage", "sidePanel"],
  "action": {
    "default_title": "Notes"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
